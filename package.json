{
  "name": "i-a-trend",
  "type": "module",
  "version": "1.0.0",
  "description": "Blog de Automação com IA para Negócios - Português Brasileiro",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && echo _worker.js > dist/.assetsignore && echo _worker.js/** >> dist/.assetsignore",
