<form class="rounded-2xl bg-gradient-to-br from-primary-600 to-accent-700 p-6 sm:p-8 text-white" onsubmit="event.preventDefault(); alert('Newsletter - configure com Beehiiv/ConvertKit');">
  <div class="max-w-lg mx-auto text-center">
    <h3 class="text-2xl font-bold mb-2">Receba as tendências de IA</h3>
    <p class="text-primary-100 mb-6 text-sm sm:text-base">
      As 10 melhores notícias de automação com IA toda semana no seu email.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder="seu@email.com.br"
        required
        class="flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-300"
      />
      <button
        type="submit"
        class="px-6 py-3 rounded-lg bg-white text-primary-700 font-semibold hover:bg-primary-50 transition-colors whitespace-nowrap"
      >
        Inscrever →
      </button>
    </div>
    <p class="text-xs text-primary-200 mt-3">
      Sem spam. Cancelamento a qualquer momento.
    </p>
  </div>
</form>