---
import { formatDateBR, getTimeAgo } from '@/utils/date';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'news'>;
  variant?: 'default' | 'compact' | 'featured';
}

const { article, variant = 'default' } = Astro.props;
const { data } = article;
---

{
  variant === 'featured' ? (
    <a
      href={`/noticia/${data.slug}`}
      class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary-900 via-primary-800 to-accent-900 min-h-[400px] sm:min-h-[480px] flex items-end"
    >
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent z-10" />
      {data.imageUrl && (
        <img
          src={data.imageUrl}
          alt={data.title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
      )}
      <div class="relative z-20 p-6 sm:p-8 w-full">
        <span class="inline-block px-3 py-1.5 text-xs font-semibold uppercase tracking-wider rounded-full bg-primary-500/20 text-primary-200 backdrop-blur-sm border border-primary-400/30 mb-4">
          {data.category === 'ia-automacao' ? '🤖 IA & Automação' :
           data.category === 'negocios-tech' ? '💼 Negócios & Tech' :
           data.category === 'startups' ? '🚀 Startups' :
           data.category === 'marketing-tech' ? '📢 Marketing' : '📡 Tech Geral'}
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-white leading-tight mb-3 group-hover:text-primary-200 transition-colors">
          {data.title}
        </h2>
        <p class="text-gray-300 line-clamp-2 mb-3">
          {data.excerpt}
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <span>{data.sourceName}</span>
          <span>•</span>
          <time datetime={data.publishedAt}>{getTimeAgo(data.publishedAt)}</time>
        </div>
      </div>
    </a>
  ) : variant === 'compact' ? (
    <a
      href={`/noticia/${data.slug}`}
      class="group flex gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors border border-gray-100 hover:border-primary-200"
    >
      {data.imageUrl && (
        <img
          src={data.imageUrl}
          alt=""
          class="w-20 h-20 rounded-lg object-cover flex-shrink-0"
          loading="lazy"
        />
      )}
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2">
          {data.title}
        </h3>
        <p class="text-sm text-gray-500 mt-1 line-clamp-1">{data.excerpt}</p>
        <div class="flex items-center gap-2 text-xs text-gray-400 mt-2">
          <span>{data.sourceName}</span>
          <span>•</span>
          <time datetime={data.publishedAt}>{getTimeAgo(data.publishedAt)}</time>
        </div>
      </div>
    </a>
  ) : (
    <a
      href={`/noticia/${data.slug}`}
      class="group flex flex-col rounded-xl border border-gray-200 hover:border-primary-300 overflow-hidden transition-all hover:shadow-lg"
    >
      {data.imageUrl && (
        <div class="aspect-video bg-gray-100 overflow-hidden">
          <img
            src={data.imageUrl}
            alt={data.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      )}
      <div class="p-5 flex-1 flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-primary-50 text-primary-700 border border-primary-200">
            {data.category === 'ia-automacao' ? 'IA & Automação' :
             data.category === 'negocios-tech' ? 'Negócios & Tech' :
             data.category === 'startups' ? 'Startups' :
             data.category === 'marketing-tech' ? 'Marketing' : 'Tech Geral'}
          </span>
          <span class="text-xs text-gray-400">{data.sourceName}</span>
        </div>
        <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2 mb-2">
          {data.title}
        </h3>
        <p class="text-sm text-gray-600 line-clamp-2 mb-3 flex-1">
          {data.excerpt}
        </p>
        <time datetime={data.publishedAt} class="text-xs text-gray-400">
          {formatDateBR(data.publishedAt, { short: true })}
        </time>
      </div>
    </a>
  )
}