---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import AdSense from '@/components/AdSense.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { getArticleBySlug, getRelatedArticles, getDB } from '@/utils/d1';
import { formatDateBR } from '@/utils/date';

const db = getDB(Astro);
const { slug } = Astro.params;

let article = null;
if (db && slug) {
  article = await getArticleBySlug(db, slug);
}

let related: any[] = [];
if (article && db) {
  related = await getRelatedArticles(db, article.data.category, article.data.slug);
}

const data = article?.data || null;

const hasBody = data && (data.contentFull || data.body) && (data.contentFull || data.body).length > 50;

const wordCount = hasBody ? (data.contentFull || data.body).split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

function formatContent(text: string): string {
  const paragraphs = text
    .split(/\n\n+/)
    .map(p => p.trim())
    .filter(p => p.length > 10);

  return paragraphs.map((p, i) => {
    const isHead = /^#+\s/.test(p);
    if (isHead) {
      const level = (p.match(/^#+/) || [''])[0].length;
      const clean = p.replace(/^#+\s*/, '');
      if (level <= 2) return `<h2 class="article-h2">${clean}</h2>`;
      return `<h3 class="article-h3">${clean}</h3>`;
    }
    if (i === 0) {
      return `<p class="article-p article-dropcap">${p.replace(/\n/g, '<br>')}</p>`;
    }
    return `<p class="article-p">${p.replace(/\n/g, '<br>')}</p>`;
  }).join('\n');
}

const categoryLabels: Record<string, { label: string; emoji: string }> = {
  'ia-automacao': { label: 'IA & Automação', emoji: '🤖' },
  'negocios-tech': { label: 'Negócios & Tech', emoji: '💼' },
  'startups': { label: 'Startups', emoji: '🚀' },
  'marketing-tech': { label: 'Marketing & Tech', emoji: '📢' },
  'tech-geral': { label: 'Tech Geral', emoji: '📡' },
};

const catInfo = data ? (categoryLabels[data.category] || { label: data.category, emoji: '📰' }) : { label: '', emoji: '📰' };
---

<Layout
  title={data ? `${data.title} | i-a-trend` : 'i-a-trend'}
  description={data?.excerpt || ''}
  image={data?.imageUrl}
  url={data ? `/noticia/${data.slug}` : '/'}
  type="article"
  publishedTime={data?.publishedAt}
  section={catInfo.label}
  tags={data?.tags || []}
>
  <Header slot="header" />

  {data ? (
    <article class="container py-8 sm:py-12 max-w-3xl">
      <header class="mb-8">
        <div class="flex flex-wrap items-center gap-2 text-sm mb-5">
          <a
            href={`/categoria/${data.category}`}
            class="inline-flex items-center gap-1 text-xs font-bold px-3 py-1.5 rounded-full bg-primary-600 text-white hover:bg-primary-700 transition-colors"
          >
            {catInfo.emoji} {catInfo.label}
          </a>
          <span class="text-gray-300">·</span>
          <time datetime={data.publishedAt} class="text-gray-500 text-xs font-medium">
            {formatDateBR(data.publishedAt, { short: true })}
          </time>
          {hasBody && (
            <>
              <span class="text-gray-300">·</span>
              <span class="text-gray-500 text-xs font-medium">{readingTime} min de leitura</span>
            </>
          )}
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-[2.5rem] font-extrabold text-gray-900 leading-[1.15] mb-5 text-balance tracking-tight">
          {data.title}
        </h1>

        <p class="text-lg sm:text-xl text-gray-500 leading-relaxed font-normal max-w-2xl">
          {data.excerpt}
        </p>

        {data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-5">
            {data.tags.map(tag => (
              <span class="px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide rounded bg-gray-100 text-gray-500">
                {tag}
              </span>
            ))}
          </div>
        )}

        <div class="mt-6 border-b border-gray-200"></div>
      </header>

      {data.imageUrl && (
        <figure class="mb-8 -mx-4 sm:mx-0">
          <img
            src={data.imageUrl}
            alt={data.title}
            class="w-full rounded-xl sm:rounded-2xl max-h-[480px] object-cover shadow-sm"
            loading="eager"
          />
        </figure>
      )}

      <AdSense />

      <div class="mt-6">
        {hasBody ? (
          <div class="prose-custom" set:html={formatContent(data.contentFull || data.body)} />
        ) : (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <p class="text-gray-700 leading-relaxed text-base">{data.excerpt}</p>
            <p class="text-gray-400 text-sm mt-4">
              Conteúdo em atualização.
            </p>
          </div>
        )}
      </div>

      <AdSense />

      {related.length > 0 && (
        <section class="mt-14 pt-8 border-t border-gray-200">
          <h2 class="text-base font-bold text-gray-900 mb-5 uppercase tracking-wide">Leia também</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {related.map(a => (
              <a
                href={`/noticia/${a.data.slug}`}
                class="group p-4 rounded-xl border border-gray-100 hover:border-primary-200 hover:shadow-sm transition-all bg-white"
              >
                {a.data.imageUrl && (
                  <img
                    src={a.data.imageUrl}
                    alt=""
                    class="w-full aspect-video object-cover rounded-lg mb-3"
                    loading="lazy"
                  />
                )}
                <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2 text-sm leading-snug">
                  {a.data.title}
                </h3>
                <p class="text-xs text-gray-400 mt-2 line-clamp-2">{a.data.excerpt}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="my-12">
        <NewsletterForm />
      </section>
    </article>
  ) : (
    <div class="container py-16 text-center">
      <h1 class="text-2xl font-bold text-gray-400 mb-2">Artigo não encontrado</h1>
      <p class="text-gray-500">O artigo que você procura não existe ou foi removido.</p>
      <a href="/" class="mt-4 inline-block text-primary-600 hover:text-primary-700 font-medium">← Voltar para home</a>
    </div>
  )}

  <Footer slot="footer" />
</Layout>
