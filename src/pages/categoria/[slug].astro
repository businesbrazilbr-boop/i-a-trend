---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import NewsCard from '@/components/NewsCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    'ia-automacao',
    'negocios-tech',
    'startups',
    'marketing-tech',
    'tech-geral',
  ];
  return categories.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const allNews = await getCollection('news');
const filtered = allNews
  .filter(a => a.data.category === slug)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const featured = filtered[0];
const rest = filtered.slice(1);

const labels: Record<string, string> = {
  'ia-automacao': '🤖 IA & Automação',
  'negocios-tech': '💼 Negócios & Tech',
  'startups': '🚀 Startups',
  'marketing-tech': '📢 Marketing & Tech',
  'tech-geral': '📡 Tech Geral',
};

const descs: Record<string, string> = {
  'ia-automacao': 'Ferramentas, LLMs, RPA, automação inteligente para negócios brasileiros.',
  'negocios-tech': 'Transformação digital, fintechs, soluções corporativas com IA.',
  'startups': 'Novos negócios, scale-ups, investimentos e inovação no Brasil.',
  'marketing-tech': 'Marketing digital, IA criativa, análise de dados e anúncios inteligentes.',
  'tech-geral': 'Tecnologia em geral, tendências e inovações do mercado brasileiro.',
};
---

<Layout title={`${labels[slug] || slug} | i-a-trend`} description={descs[slug] || ''} url={`/categoria/${slug}`}>
  <Header slot="header" />

  <section class="container py-8">
    <div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
      <a href="/" class="hover:text-primary-600 transition-colors">Home</a>
      <span>/</span>
      <span class="text-gray-600 font-medium">{labels[slug] || slug}</span>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">{labels[slug] || slug}</h1>
    <p class="text-gray-600 mb-8">{descs[slug] || ''}</p>

    {filtered.length > 0 ? (
      <>
        {featured && (
          <div class="mb-8">
            <NewsCard article={featured} variant="hero" />
          </div>
        )}

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {rest.map(article => <NewsCard article={article} />)}
        </div>
      </>
    ) : (
      <div class="text-center py-16 text-gray-400">
        <p class="text-lg">Nenhuma notícia nesta categoria ainda.</p>
        <p class="text-sm mt-2">Aguardando o Worker popular o conteúdo...</p>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</Layout>